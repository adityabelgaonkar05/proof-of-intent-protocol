# ============================================================
#  POIP Demo — environment configuration
#  Copy this to .env and fill in your testnet keys
# ============================================================

# ----------------------------------------------------------
# Ethereum wallet private keys (Sepolia testnet ONLY)
# ----------------------------------------------------------
PRIVATE_KEY=             # User wallet — signs the root intent
DEPLOYER_KEY=            # Orchestrator wallet — creates delegations
RESEARCH_KEY=            # Research agent wallet — creates sub-delegations
EXECUTION_KEY=           # Execution agent wallet — executes the swap

# ----------------------------------------------------------
# Optional: Claude API for natural language intent parsing
# Without this, the demo uses hardcoded intent parameters.
# ----------------------------------------------------------
CLAUDE_API_KEY=

# ----------------------------------------------------------
# Optional: RPC override (defaults to Sepolia public node)
# ----------------------------------------------------------
# RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ----------------------------------------------------------
# 0G Network — decentralised storage for intent NFTs (OPTIONAL)
# The protocol works fully without this. Leaving ZG_API_KEY blank
# simply skips off-chain storage; all on-chain guarantees remain.
# To enable: get A0GI tokens from https://faucet.0g.ai
# ----------------------------------------------------------
ZG_API_KEY=                    # optional — private key on 0G network (hex with 0x)
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
