# ============================================================
#  Proof-of-Intent Protocol — SDK integration
# ============================================================
#
#  This file is for developers embedding the SDK in their own
#  agent codebase.  Copy to .env and fill in your values.
#
#  For running the full reference pipeline (orchestrator,
#  multi-agent delegation, quickstart examples) see .env.example.
# ============================================================

# Your wallet private key (hex with or without 0x prefix, Sepolia testnet only)
PRIVATE_KEY=

# Optional: only required if you call compile_intent() to translate
# natural-language instructions into structured IntentData objects.
CLAUDE_API_KEY=
