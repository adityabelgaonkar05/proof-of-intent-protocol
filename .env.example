# ============================================================
#  Proof-of-Intent Protocol — environment configuration
# ============================================================

# ----------------------------------------------------------
# Anthropic / OpenAI
# ----------------------------------------------------------
USE_CLAUDE=false
CLAUDE_API_KEY=
OPENAI_API_KEY=

# ----------------------------------------------------------
# Network (EVM)
# ----------------------------------------------------------
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
CHAIN_ID=11155111

# ----------------------------------------------------------
# Wallet private keys — testnet only
# ----------------------------------------------------------
DEPLOYER_PRIVATE_KEY=
ORCHESTRATOR_PRIVATE_KEY=   # same key as DEPLOYER for this setup
USER_PRIVATE_KEY=
RESEARCH_PRIVATE_KEY=
EXECUTION_PRIVATE_KEY=

# ----------------------------------------------------------
# Agent Ethereum addresses (derived from keys above)
# ----------------------------------------------------------
ORCHESTRATOR_ADDRESS=
RESEARCH_ADDRESS=
EXECUTION_ADDRESS=

# ----------------------------------------------------------
# Optional token address overrides
# ----------------------------------------------------------
# USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
# WETH_ADDRESS=0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14

# ----------------------------------------------------------
# 0G Network — decentralised storage for intent NFTs
# Private key must hold A0GI tokens on 0G Newton testnet
# for gas. Get tokens from: https://faucet.0g.ai
# ----------------------------------------------------------
0G_API_KEY=                                                     # private key on 0G network (hex with 0x)
0G_RPC_URL=https://evmrpc-testnet.0g.ai                         # 0G Newton testnet EVM RPC
0G_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai      # 0G storage indexer

# ----------------------------------------------------------
# ENS text record — set to your ENS name to link active intents
# The signing wallet must be the ENS controller for this name.
# ----------------------------------------------------------
ENS_NAME=

# ----------------------------------------------------------
# Contract addresses — AUTO-POPULATED by ./deploy.sh
# config.py reads from config/deployed.json, not here
# ----------------------------------------------------------
