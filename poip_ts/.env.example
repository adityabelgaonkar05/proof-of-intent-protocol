# ============================================================
#  proof-of-intent TypeScript SDK
# ============================================================
#  Copy this file to .env and fill in your values.
#  See the project root .env.example for the full pipeline.
# ============================================================

# Your wallet private key (hex with or without 0x prefix, Sepolia testnet only)
PRIVATE_KEY=

# Optional: only required if you call compileIntent()
CLAUDE_API_KEY=

# ----------------------------------------------------------
# 0G Network — decentralised storage for intent NFTs (OPTIONAL)
# The SDK works fully without this. Leaving ZG_API_KEY blank
# simply skips off-chain storage; all on-chain guarantees remain.
# To enable: get A0GI tokens from https://faucet.0g.ai
# ----------------------------------------------------------
ZG_API_KEY=                    # optional — private key on 0G network (hex with 0x)
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
